# ─── Server ───────────────────────────────────────────
PORT=3400
BASE_URL=http://YOUR_SERVER_IP:3400

# ─── Database (isolated — do not share with other apps) ─
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gs_graphics_db
DB_USER=gs_graphics_user
DB_PASSWORD=CHANGE_ME

# ─── Session ──────────────────────────────────────────
SESSION_SECRET=GENERATE_WITH_CRYPTO

# ─── Admin Credentials ────────────────────────────────
ADMIN_USERNAME=admin
# Generate with: node scripts/hash-password.js yourPassword
ADMIN_PASSWORD_HASH=GENERATE_ME

# ─── Square Payments ──────────────────────────────────
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=SQUARE_PLACEHOLDER
SQUARE_LOCATION_ID=SQUARE_PLACEHOLDER

# ─── Branding (per deployment) ────────────────────────
BRAND_NAME=GS Graphics
BRAND_TAGLINE=Custom Apparel for Your School & Team
BRAND_COLOR=#e63946
BRAND_LOGO_URL=
